{
  "manifest_version": 3,
  "name": "ACM DL PDF Redirector",
  "version": "1.0.0",
  "description": "Opens ACM Digital Library papers in your browser's default PDF viewer instead of ACM's eReader, by rewriting epdf links to pdf.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["*://dl.acm.org/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "acmdl_ruleset",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://dl.acm.org/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
